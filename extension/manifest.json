{
  "name": "Formerly",
  "version": "1.0",
  "description": "An extension that creates all the google forms for you with a simple prompt.",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "scripting",
    "identity"
  ],
  "oauth2": {
    "client_id": "721197352862-0r5h8a4o500me6i4f5hn4no8ciescq12.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/forms.body"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "formerly@formerly.com"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "static/popup.html"
  }
}