{
  "name": "Formerly",
  "version": "1.0",
  "description": "An extension that creates all the google forms for you with a simple prompt.",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "scripting",
    "identity"
  ],
  "host_permissions": [
    "http://localhost:3000/",
    "https://forms.googleapis.com/"
  ],
  "oauth2": {
    "client_id": "721197352862-3gqq00qkjt21pds2bbtkp4u7go6qf6cn.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/forms.body"
    ]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "formerly@formerly.com"
    }
  },
  "background": {
    "service_worker": "background.js",
    "scripts": ["js/browser-polyfill.js", "background.js"]
  },
  "action": {
    "default_popup": "static/popup.html"
  }
}