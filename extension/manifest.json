{
  "name": "Formerly",
  "version": "1.0",
  "description": "An extension that creates all the google forms for you with a simple prompt.",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "formerly@formerly.com"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "js": [
        "js/browser-polyfill.js",
        "js/content-script.js"
      ],
      "matches": [
        "https://docs.google.com/forms/*"
      ]
    }
  ],
  "action": {
    "default_popup": "static/popup.html",
    "default_icon": "icon.png"
  }
}