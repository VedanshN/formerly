{
  "name": "Formerly",
  "version": "1.0",
  "description": "An extension that creates all the google forms for you with a simple prompt.",
  "manifest_version": 3,
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "js": [
        "js/browser-polyfill.js",
        "js/content-script.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png"
  }
}